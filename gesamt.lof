\contentsline {figure}{\numberline {5.1}{\ignorespaces Verification of feature importance implementations on a linear model with known weights. Bars show estimated weight; black markers indicate the true weights.}}{21}{figure.caption.10}%
\contentsline {figure}{\numberline {5.2}{\ignorespaces Centered ICE curves and PD line (black) for sensor s9 on the single-FD001 model. Each coloured line represents one test instance.}}{23}{figure.caption.11}%
